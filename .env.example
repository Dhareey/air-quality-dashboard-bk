# Copy to .env and fill in. Required: AIRQO_API_KEY.
# On EC2, create this file next to docker-compose.yml (or set env another way).

AIRQO_API_KEY=

# CORS (optional; default in settings.py is all origins: ["*"])
# ALLOWED_ORIGINS='["https://example.com","http://localhost:3000"]'

# Cerebras (optional; leave empty to disable LLM features that need it)
CEREBRAS_API_KEY=
